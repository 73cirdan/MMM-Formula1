<div> {{ birthdays | dump }} </div>

{% if loading %}
  <div class="small dimmed light">
    {{ "LOADING" | translate | safe }}
  </div>
{% else %}

<table class="small align-left">
<!-- Start the Standings and Schedule tables -->
{% if "DRIVER" | showStanding %}
    <thead>
      <tr class="normal">
        <td class="light "><span class="symbol fa fa-wrench"></span></td>
        <td class="light align-right rightpad"><span class="fa fa-ranking-star"></span></td>
        <td>{{ "DRIVER" | translate | safe }}</td>
        <td class="light"><span class="symbol fa fa-globe"></span></td>
        <td class="light align-right "><span class="fa fa-line-chart"></span></td>
        <td class="light align-right "><span class="fa fa-trophy"></span></td>
      </tr>
    </thead>
    <tbody>
      {% if dataD === null %}
        <tr class="small dimmed light">
          <td colspan="5" text-align="center">{{ "NO DATA" | translate | safe }}</td>
        </tr>
      {% else %}
        {% for standing in dataD.DriverStandings %}
          <tr class="normal" style="opacity: {{ loop.index | getFadeOpacity(loop.length) }};">
            <td class="title bright">
              <img class="{{ "grayscale" if config.grayscale }}" src="{{ endpointconstructors }}{{ standing.Constructors[0].constructorId }}.png" height="27"></img>
            </td>
            <td class="bright align-right rightpad">{{ standing.position }}</td>
            <td class="title bright">{{ standing.Driver.givenName }} {{ standing.Driver.familyName }}</td>
            <td class="light">
              <div class="flag flag-{{ standing.Driver.nationality | getCodeFromNationality }} {{ " grayscale" if config.grayscale }}"></div>
            </td>
            <td class="bright align-right">{{ standing.points }}</td>
            <td class="bright align-right">{{ standing.wins }}</td>
          </tr>
        {% endfor %}
      {% endif %}
    </tbody>
{% endif %}

{% if "CONSTRUCTOR" | showStanding %}
  <thead>
    <tr class="normal">
      <td class="light"><span class="symbol fa fa-wrench"></span></td>
      <td class="light align-right rightpad"><span class="fa fa-ranking-star"></span></td>
      <td>{{ "CONSTRUCTOR" | translate }}</td>
      <td class="light"><span class="symbol fa fa-globe"></span></td>
      <td class="light align-right"><span class="fa fa-line-chart"></span></td>
      <td class="light align-right"><span class="fa fa-trophy"></span></td>
    </tr>
  </thead>
  <tbody>
    {% if dataC === null %}
      <tr class="small dimmed light">
        <td colspan="5" text-align="center">{{ "NO DATA" | translate | safe }}</td>
      </tr>
    {% else %}
      {% for standing in dataC.ConstructorStandings %}
        <tr class="normal" style="opacity: {{ loop.index | getFadeOpacity(loop.length) }};">
          <td class="title bright">
            <img class="{{ "grayscale" if config.grayscale }}" src="{{ endpointconstructors }}{{ standing.Constructor.constructorId }}.png" height="27"></img>
          </td>
          <td class="bright align-right rightpad">{{ standing.position }}</td>
          <td class="title bright">{{ standing.Constructor.name }}</td>
          <td class="light">
            <div class="flag flag-{{ standing.Constructor.nationality | getCodeFromNationality }} {{ " grayscale" if config.grayscale }}"></div>
          </td>
          <td class="bright align-right">{{ standing.points }}</td>
          <td class="bright align-right">{{ standing.wins }}</td>
        </tr>
      {% endfor %}
    {% endif %}
  </tbody>
{% endif %}
</table>

{% if config.showSchedule %}
  <table class="small align-left">
    <thead>
      <tr class="normal">
        <td>{{ "RACE_DETAILS" | translate }}</td>
        <td>{{ "CIRCUIT_LAYOUT" | translate }}</td>
      </tr>
    </thead>
    <tbody>
      {% if dataS === null %}
        <tr class="small dimmed light">
          <td colspan="2" text-align="center">{{ "NO DATA" | translate | safe }}</td>
        </tr>
      {% else %}
        <tr class="title bright">
          <td class="small">{{ "SEASON" | translate }}: {{ dataS.season }}, {{ "ROUND" | translate }}: {{ dataS.round }}</td>
          <td rowspan="7" class="align-right">
            <img src="{{ endpointtracks }}{{ dataS.circuitImage }}" height="155"></img>
            {% if not config.grayscale %}
              <div>
                <span class="xsmall" style="color: #EF4444">S1</span>
                <span class="xsmall" style="color: #3B82F6">S2</span>
                <span class="xsmall" style="color: #FBBF24">S3</span>
              </div>
            {% endif %}
          </td>
        </tr>
        <tr class="title bright">
          <td class="small">{{ dataS.raceName }}</td>
        </tr>
        {% if dataS.pract1Date %}
          <tr class="title">
            <td class="small">{{ "FP1_DATE" | translate }}: {{ dataS.pract1Date|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.pract2Date %}
          <tr class="title">
            <td class="small">{{ "FP2_DATE" | translate }}: {{ dataS.pract2Date|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.pract3Date %}
          <tr class="title">
            <td class="small">{{ "FP3_DATE" | translate }}: {{ dataS.pract3Date|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.sprintQualifyingDate %}
          <tr class="title bright">
            <td class="small">{{ "SPRINT_DATE" | translate }} {{ "QUALI_DATE" | translate }}: {{ dataS.sprintQualifyingDate|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.sprintDate %}
          <tr class="title bright">
            <td class="small">{{ "SPRINT_DATE" | translate }}: {{ dataS.sprintDate|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.qualifyingDate %}
          <tr class="title bright">
            <td class="small">{{ "QUALI_DATE" | translate }}: {{ dataS.qualifyingDate|safe }}</td>
          </tr>
        {% endif %}
        {% if dataS.raceDate %}
          <tr class="title bright">
            <td class="small">{{ "RACE_DATE" | translate }}: {{ dataS.raceDate|safe }}</td>
          </tr>
        {% endif %}
      {% endif %}
    </tbody>
  </table>
    {% if (dataS and config.showNextRace ) %}
        <table class="small align-left">
            <tr class="title light">
                {% if (dataS.nextRaceDate ) %}
                        <td class="small" text-align="center">{{ "NEXT_RACE" | translate }}: {{ dataS.nextRaceDate|safe }}: {{ dataS.nextRaceName }}</td>
                {% else %}
                        <td class="small" text-align="center">{{ "LAST_RACE" | translate }}</td>
                {% endif %}
            </tr>
        </table>
    {% endif %} <!-- show next race -->
{% endif %} <!-- showSchedule -->

{% if hasBirthday %}
  <div class="f1-birthday-container">
    {% for driver in dataDriverProfiles %}
      <div class="f1-card" style="border-left: 5px solid {% if config.grayscale %}#FFFFFF{% else %}{{ driver.team_colour }}{% endif %};">

        
        <!-- Top row: Driver details -->
          <div class="f1-name title bright">
            <span>
              <i class="fa fa-birthday-cake"></i> 
              {{ driver.name }} #{{ driver.number }} {{ driver.age }} {{ "YRS" | translate }}  
            </span>
          </div>
          <div class="f1-flaglogo">
              <i class="flag flag-{{ driver.nationality | getCodeFromNationality }} {{ " grayscale" if config.grayscale }}"></i>
          </div>

        <!-- Avatar section -->
  <img class="f1-avatar {% if config.grayscale %}grayscale{% endif %}" 
       style="border: 3px solid {% if config.grayscale %}#FFFFFF{% else %}{{ driver.team_colour }}{% endif %};"
{% if driver.image %}
       src="{{ driver.image }}"
{% endif %}
 />

        <!-- Constructor section -->
          <div class="f1-team">
            {{ driver.team }} 
          </div>
          <div class="f1-constructorlogo">
              <img class="{{ "grayscale" if config.grayscale }}" src="{{ endpointconstructors }}{{ driver.team_id }}.png" height="50">
          </div>
        <!-- Stats section -->
        <div class="f1-stats">
          <span>{{ driver.year }} {% if driver.position != "-" %}P{{ driver.position }}{% else %}—{% endif %} {{ driver.points }} pts</span>
        </div>

        <!-- Career title section -->
        <div class="f1-career bright" style="border-bottom: 1px solid {% if config.grayscale %}#FFFFFF{% else %}{{ driver.team_colour }}{% endif %};"> 
 		{{ "CAREER_HIGHLIGHTS" |  translate }}
        </div>

        <!-- Career Facts -->
        <div class="f1-highlights1">
	    <div><b>{{ "CHAMPIONSHIP" | translate }}:</b> {{ driver.total_championship_wins }} <i class="fa fa-trophy"></i> | 
            <i class="fa-solid fa-arrow-up-1-9"></i> P{{ driver.best_championship_position }} </div>
        </div>
        <div class="f1-highlights2">
            <div> <b>{{ "RACE" | translate }}</b> #:{{ driver.total_race_entries }} | 
              {{ driver.total_podiums }} <i class="fa fa-ranking-star"></i> | 
              {{ driver.total_race_wins }}  <i class="fa fa-trophy"></i> | 
 	      <i class="fa-solid fa-arrow-up-1-9"></i> P{{ driver.best_race_result }} </div>
        </div>
        <div class="f1-highlights3">
	    <div>#{{ "FASTEST_LAP" | translate }}: {{ driver.total_fastest_laps }} | #{{ "DRIVER_OT_DAY" | translate }}: {{ driver.total_driver_of_the_day }}</div>
        </div>
        
      </div> <!-- Close the f1-card here -->
    {% endfor %}
  </div>  <!-- Close the birthday container here -->
{% endif %} <!-- End birthday card -->

          <!-- New Stats Section (Small font size) 
          <div class="f1-stats-details" style="font-size: 0.85em; color: #555;">
            <div><strong>Race Laps:</strong> {{ driver.total_race_laps }}</div>
            <div><strong>Best Grid Position:</strong> P{{ driver.best_starting_grid_position }}</div>
          </div>
-->
{% endif %}


