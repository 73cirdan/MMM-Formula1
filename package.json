{
  "name": "mmm-formula1",
  "version": "3.0.0",
  "description": "A Formula 1 module for MagicMirror².",
  "scripts": {
    "test": "npm run test:prettier && npm run test:js && npm run test:css && npm run test:unit",
    "test:unit": "vitest run --config vitest.config.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:prettier": "prettier --check **/*.{js,css,json,md,yml}",
    "test:js": "eslint *.js --config .eslint.config.cjs --quiet",
    "test:css": "stylelint **/*.css --config .stylelintrc.json",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:prettier",
    "lint:prettier": "prettier --write **/*.{js,css,json,md,yml}",
    "lint:js": "eslint *.js --config .eslint.config.cjs --fix",
    "lint:css": "stylelint **/*.css --config .stylelintrc.json --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianperrin/MMM-Formula1"
  },
  "keywords": [
    "magic mirror",
    "smart mirror",
    "Formula1",
    "module"
  ],
  "author": "Ian Perrin/Cirdan ",
  "contributors": "https://github.com/ianperrin/MMM-Formula1/graphs/contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ianperrin/MMM-Formula1/issues"
  },
  "homepage": "https://github.com/ianperrin/MMM-Formula1#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "globals": "^17.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "vitest": "^4.1.0"
  }
}
